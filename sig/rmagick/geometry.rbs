module Magick
  class Geometry
    attr_accessor width: magick_real
    attr_accessor height: magick_real
    attr_accessor x: Numeric
    attr_accessor y: Numeric
    attr_accessor flag: GeometryValue?

    def initialize: (?magick_real? width, ?magick_real? height, ?Numeric? x, ?Numeric? y, ?GeometryValue? flag) -> void
    def self.from_s: (String str) -> Geometry
    def to_s: -> String
  end
end

